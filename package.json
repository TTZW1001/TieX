{
  "name": "tiex",
  "version": "1.0.0",
  "description": "TieX - Windows 本地桌面 AI 智能体工作台",
  "author": "TieX",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "postinstall": "npm run rebuild:node",
    "rebuild": "npm run rebuild:electron",
    "rebuild:node": "npm rebuild better-sqlite3",
    "rebuild:electron": "npm rebuild better-sqlite3 --runtime=electron --target=29.4.6 --dist-url=https://electronjs.org/headers",
    "predev": "npm run rebuild:electron",
    "dev": "vite",
    "prebuild": "npm run rebuild:electron",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{js,ts,vue,css}\" \"electron/**/*.{js,ts}\"",
    "pretest": "npm run rebuild:node",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "npm run rebuild:electron",
    "pack": "electron-builder --dir",
    "predist": "npm run rebuild:electron",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.7",
    "better-sqlite3": "^12.11.1",
    "docx": "^9.7.1",
    "fast-glob": "^3.3.3",
    "lucide-vue-next": "^0.344.0",
    "markdown-it": "^14.2.0",
    "pinia": "^2.1.7",
    "pptxgenjs": "^4.0.1",
    "shiki": "^4.2.0",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/markdown-it": "^14.1.2",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.23.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.9",
    "vue-tsc": "^2.0.6"
  }
}
